{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "outDir": "dist/main",
    "rootDir": "electron/main",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "electron/main/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
