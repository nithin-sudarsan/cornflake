# Python sidecar — set to the interpreter that has resemblyzer/soundfile installed.
# Run `which python3` inside your venv/conda env to find the right path.
PYTHON_PATH=/opt/anaconda3/bin/python3

# LLM
LLM_PROVIDER=claude               # claude | openai | grok
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=

# Deepgram
DEEPGRAM_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WorkOS SSO
# 1. Create an AuthKit app at workos.com and enable Google OAuth provider
# 2. In WorkOS dashboard → Redirects, add BOTH:
#      cornflake://auth/callback          (fallback deep link)
#      http://127.0.0.1:52069/callback    (primary localhost callback — fixes browser spinner)
# 3. Enable "Return Google OAuth tokens" and add scope: calendar.readonly
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=cornflake://auth/callback
# Port for the localhost OAuth callback server. Must match the redirect URI registered above.
WORKOS_CALLBACK_PORT=52069

# Comms (Cornflake-hosted — not user-configurable)
SENDGRID_API_KEY=
SENDGRID_FROM_ADDRESS=hello@cornflake.app
