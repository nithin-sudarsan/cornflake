{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "electron/renderer/src/**/*.ts",
    "electron/renderer/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
